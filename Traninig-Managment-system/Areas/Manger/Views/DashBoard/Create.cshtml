@model CreateUserVm

<div class="user-form-container">
    <h2><i class="bi bi-person-plus me-2"></i>Create New User</h2>
    <div asp-validation-summary="All" class="text-danger"></div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <!-- Name -->
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input asp-for="Name" class="form-control" placeholder="Enter username" />
            </div>
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <!-- Email -->
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                <input asp-for="Email" class="form-control" placeholder="Enter email" />
            </div>
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <!-- Password -->
        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                <input asp-for="Password" type="password" class="form-control" />
            </div>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <!-- Role Selection -->
        <div class="mb-3">
            <label asp-for="SelectedRole" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-shield"></i></span>
                <select asp-for="SelectedRole"
                        asp-items="ViewBag.Roles"
                        class="form-select"
                        id="roleSelect">
                    <option value="">-- Select Role --</option>
                </select>
            </div>
            <span asp-validation-for="SelectedRole" class="text-danger"></span>
        </div>

        <!-- Plan Selection (يظهر فقط للـ Company) -->
        <div class="mb-4" id="planContainer" style="display: none;">
            <label asp-for="SelectedPlanId" class="form-label">Subscription Plan</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-box-seam"></i></span>
                <select asp-for="SelectedPlanId"
                        asp-items="ViewBag.Plans"
                        class="form-select"
                        id="planSelect">
                    <option value="">-- Select Plan --</option>
                </select>
            </div>
            <span asp-validation-for="SelectedPlanId" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i> Create User
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i> Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const roleSelect = document.getElementById('roleSelect');
            const planContainer = document.getElementById('planContainer');
            const planSelect = document.getElementById('planSelect');

            // الـ Company role name (عدّله لو مختلف عندك)
            const companyRole = 'Company';

            function togglePlanVisibility() {
                if (roleSelect.value === companyRole) {
                    planContainer.style.display = 'block';
                } else {
                    planContainer.style.display = 'none';
                    planSelect.value = ''; // Reset selection
                }
            }

            // Check on page load (مهم للـ validation errors)
            togglePlanVisibility();

            // Check on change
            roleSelect.addEventListener('change', togglePlanVisibility);
        });
    </script>
}