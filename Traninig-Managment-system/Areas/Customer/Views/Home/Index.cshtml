 @model MainPageVm

<!-- Hero Section -->
<section class="hero-section" id="home">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="hero-content">
                    <h1 class="hero-title">Transform Your Team with Professional Training</h1>
                    <p class="hero-subtitle">
                        Upload, manage, and deliver exceptional training courses to your
                        organization with our cutting-edge platform trusted by industry leaders.
                    </p>
                    <button class="btn btn-cta">Start Free Trial</button>

                    <div class="hero-stats">
                        <div class="row">
                            <div class="col-4">
                                <div class="stat-item">
                                    <span class="stat-number" data-count="500">0</span>
                                    <span class="stat-label">Companies Trust Us</span>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="stat-item">
                                    <span class="stat-number" data-count="50000">0</span>
                                    <span class="stat-label">Courses Delivered</span>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="stat-item">
                                    <span class="stat-number" data-count="1000000">0</span>
                                    <span class="stat-label">Learners Trained</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="text-center">
                    <i class="fas fa-chalkboard-teacher" style="font-size: 15rem; opacity: 0.1;"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Companies Section -->
<section class="companies-section">
    <div class="container-fluid">
        <h3 class="companies-title">Trusted by Industry Leaders</h3>
        <div class="logos-container">
            <div class="logos-scroll">
                @foreach (var item in Model.Companies)
                {
                    <div class="logo-item">
                        <div style="background: #1a73e8; color: white; padding: 15px 25px; border-radius: 8px; font-weight: 600;">
                            @item.Name
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="services-section" id="services">
    <div class="container">
        <h2 class="services-title">Comprehensive Training Solutions</h2>
        <p class="services-subtitle">
            Everything you need to create, manage, and deliver world-class training
            programs
        </p>

        <div class="row">
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-cloud-upload-alt"></i>
                    </div>
                    <h4 class="service-title">Easy Course Upload</h4>
                    <p class="service-description">
                        Seamlessly upload and organize your training materials with our
                        intuitive drag-and-drop interface. Support for all major file formats.
                    </p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-users-cog"></i>
                    </div>
                    <h4 class="service-title">User Management</h4>
                    <p class="service-description">
                        Advanced user management system with role-based access, progress
                        tracking, and detailed analytics for administrators.
                    </p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h4 class="service-title">Advanced Analytics</h4>
                    <p class="service-description">
                        Comprehensive reporting and analytics to track learner progress,
                        course effectiveness, and ROI measurement.
                    </p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                    <h4 class="service-title">Mobile Learning</h4>
                    <p class="service-description">
                        Fully responsive design ensures your courses look perfect on any
                        device. Native mobile apps available.
                    </p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-certificate"></i>
                    </div>
                    <h4 class="service-title">Certification System</h4>
                    <p class="service-description">
                        Automated certificate generation and digital badge system to
                        recognize learner achievements and compliance.
                    </p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h4 class="service-title">24/7 Support</h4>
                    <p class="service-description">
                        Dedicated customer success team available around the clock to
                        ensure your training programs run smoothly.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Pricing Section -->
<section class="pricing-section" id="pricing">
    <div class="container">
        <h2 class="pricing-title">Choose Your Perfect Plan</h2>
        <p class="pricing-subtitle">Flexible pricing options designed to grow with your organization</p>

        <div class="row justify-content-center">
            @foreach (var item in Model.Plans)
            {
                <div class="col-lg-4 col-md-6" >
                    <div class="pricing-card">
                        <h3 class="plan-name">@item.Name</h3>
                        <div class="plan-price">@item.Price<small>/month</small></div>
                        <p class="plan-period">Perfect for small teams</p>
                        <ul class="plan-features">
                            <li>Duration Days:@item.DurationInDays</li>
                            <li>Max course:@item.MaxCourses</li>
                            <li class="text-uppercase">Max employee:@item.MaxEmployees</li>
                
                        </ul>
                        <button class="btn btn-plan">Start Free Trial</button>
                    </div>
                </div>
            }
            
              
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section class="testimonials-section">
    <div class="container">
        <h2 class="testimonials-title">What Our Clients Say</h2>
        <div class="row">
            <div class="col-lg-4 col-md-6">
                <div class="testimonial-card">
                    <p class="testimonial-text">
                        "LearnPro transformed our training approach. The platform is
                        intuitive and our employee engagement has increased by 300%."
                    </p>
                    <div class="testimonial-author">
                        <div class="author-avatar">JS</div>
                        <div class="author-info">
                            <h5>Jennifer Smith</h5>
                            <p>HR Director, TechGlobal</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="testimonial-card">
                    <p class="testimonial-text">
                        "The analytics dashboard gives us incredible insights into our
                        training effectiveness. ROI tracking has never been easier."
                    </p>
                    <div class="testimonial-author">
                        <div class="author-avatar">MJ</div>
                        <div class="author-info">
                            <h5>Michael Johnson</h5>
                            <p>L&D Manager, InnovCorp</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="testimonial-card">
                    <p class="testimonial-text">
                        "Outstanding customer support and a platform that just works. Our
                        compliance training is now seamless and automated."
                    </p>
                    <div class="testimonial-author">
                        <div class="author-avatar">SW</div>
                        <div class="author-info">
                            <h5>Sarah Wilson</h5>
                            <p>Training Coordinator, Futur></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>