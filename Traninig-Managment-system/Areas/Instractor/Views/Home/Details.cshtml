@model CourseDetailsVm

<!-- Breadcrumb -->
<nav class="breadcrumb">
    <a href="/Instractor/Home/DashBoard">Dashboard</a>
    <i class="fas fa-chevron-right"></i>
   
    <span>@Model.Title</span>
</nav>

<!-- Course Header Card -->
<div class="course-header-card">
    <div class="course-header-top">
        <div class="course-title-area">
            <h1>@Model.Title</h1>
            <span class="course-category">
                <i class="fas fa-code"></i> Web Development
            </span>
        </div>
        <div class="course-actions-header">
            <span class="status-badge published"><i class="fas fa-check-circle"></i> Published</span>
            <button class="btn btn-secondary"><i class="fas fa-edit"></i> Edit Course</button>
            <a asp-area="Instractor" asp-controller="InstructorLessons" asp-action="CreateLessons" asp-route-courseId="@Model.Id"
                class="btn btn-primary"><i class="fas fa-plus"></i> Add Lesson</a>
        </div>
    </div>

    <div class="course-stats">
        <div class="stat-item">
            <div class="number">12</div>
            <div class="label">@Model.Lessons.Count</div>
        </div>
        <div class="stat-item accent-green">
            <div class="number">8</div>
            <div class="label">Published</div>
        </div>
        <div class="stat-item accent-orange">
            <div class="number">4</div>
            <div class="label">Drafts</div>
        </div>
        <div class="stat-item">
            <div class="number">156</div>
            <div class="label">Enrolled</div>
        </div>
    </div>

    <div class="course-progress-section">
        <div class="progress-header">
            <span>Course Completion</span>
            <span class="percentage">85%</span>
        </div>
        <div class="progress-bar-large">
            <div class="fill" style="width: 85%;"></div>
        </div>
    </div>
</div>

<!-- Course Details Section -->
<section class="section-container">
    <div class="section-header">
        <div class="section-header-left">
            <i class="fas fa-info-circle"></i>
            <h2>Course Details</h2>
        </div>
    </div>
    <div class="section-body">
        <div class="course-info-grid">
            <div class="info-card">
                <h3>Description</h3>
                <p>@Model.Description</p>
            </div>
            <div class="info-card">
                <h3>Learning Objectives</h3>
                <p>
                    • Understand closures and scope chains<br>
                    • Master prototypal inheritance<br>
                    • Work with Promises and async/await<br>
                    • Apply modern ES6+ features
                </p>
            </div>
            <div class="info-card">
                <h3>Prerequisites</h3>
                <div class="tag-list">
                    <span class="tag">Basic JavaScript</span>
                    <span class="tag">HTML & CSS</span>
                    <span class="tag">Programming Fundamentals</span>
                </div>
            </div>
            <div class="info-card">
                <h3>Course Duration</h3>
                <p><i class="fas fa-clock" style="color: var(--primary); margin-right: 0.5rem;"></i> @Model.DurationInHours • 12 lessons • Updated 2 weeks ago</p>
            </div>
        </div>
    </div>
</section>

<!-- Course Lessons Section -->
<section class="section-container">
    <div class="section-header">
        <div class="section-header-left">
            <i class="fas fa-play-circle"></i>
            <h2>Course Lessons</h2>
        </div>
        <a asp-area="Instractor"
           asp-controller="InstructorLessons"
           asp-action="CreateLessons"
           asp-route-courseId="@Model.Id"
           class="btn btn-success"
           style="font-size: 0.8rem; padding: 0.5rem 1rem;">
            <i class="fas fa-plus"></i> New Lesson
        </a>
    </div>

    <div class="section-body">
        <div class="lessons-list">
            @if (Model.Lessons != null && Model.Lessons.Any())
            {
                int counter = 1;
                @foreach (var lesson in Model.Lessons.OrderBy(l => l.Order))
                {
                    <div class="lesson-row">
                        <div class="lesson-number">@counter</div>

                        <div class="lesson-info">
                            <div class="lesson-title">@lesson.Title</div>
                            <div class="lesson-meta">
                                <span><i class="fas fa-sort-numeric-down"></i> Order: @lesson.Order</span>

                                @if (!string.IsNullOrEmpty(lesson.Description))
                                {
                                    <span class="text-muted">| @(lesson.Description.Length > 50 ? lesson.Description.Substring(0, 50) + "..." : lesson.Description)</span>
                                }

                                <span class="status-badge published" style="padding: 0.15rem 0.5rem; font-size: 0.7rem;">Active</span>
                            </div>
                        </div>

                        <div class="lesson-actions">
                            <a href="@lesson.ContentUrl" target="_blank" class="btn-icon view" title="Preview File">
                                <i class="fas fa-eye"></i>
                            </a>

                            <a asp-area="Instractor"
                               asp-controller="InstructorLessons"
                               asp-action="EditLessons"
                               asp-route-lessonId="@lesson.Id"
                               asp-route-courseId="@Model.Id"
                               class="btn-icon edit"
                               title="Edit Lesson">
                                <i class="fas fa-edit"></i>
                            </a>


                            <button class="btn-icon delete" title="Delete Lesson">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    counter++;
                }
            }
            else
            {
                <div class="empty-state-simple" style="text-align: center; padding: 2rem; color: var(--text-secondary);">
                    <i class="fas fa-folder-open" style="font-size: 3rem; margin-bottom: 1rem; color: var(--border-color);"></i>
                    <p>No lessons added to this course yet.</p>
                </div>
            }
        </div>
    </div>
</section>

