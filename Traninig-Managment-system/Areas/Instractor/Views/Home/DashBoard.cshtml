@model InstractorDashVm

    <!-- Page Title -->
    <div class="page-title">
        <h1>Instructor Dashboard</h1>
        <p>Manage your categories, courses, and track employee progress</p>
    </div>

    <!-- ========================================
         1️⃣ TOP SUMMARY CARDS SECTION
         ======================================== -->
    <section class="summary-cards">
        @* <div class="summary-card">
            <div class="number">@Model.Categories</div>
            <div class="label">Total Categories</div>
        </div> *@
        <div class="summary-card accent-secondary">
            <div class="number">@Model.TotalCourses</div>
            <div class="label">Total Courses</div>
        </div>
        <div class="summary-card accent-warning">
            <div class="number">@Model.TotalEmployees</div>
            <div class="label">Total Employee</div>
        </div>
    </section>

    <!-- ========================================
         2️⃣ INSTRUCTOR CATEGORIES & COURSES SECTION
         ======================================== -->
    <section class="section-container">
        <div class="section-header">
            <i class="fas fa-layer-group"></i>
            <h2>Categories & Courses</h2>
        </div>
        <div class="section-body">
            <div class="category-grid">

            @foreach (var item in Model.Categories)
            {
                <!-- Category 2 -->
                <div class="category-card">
                    <div class="category-header">
                        <h3>
                            <i class="fas fa-database me-2"></i>
                            @item.CategoryName
                        </h3>
                        <span class="category-badge">@item.Courses.Count</span>
                    </div>
                    <div class="category-courses">

                        <!-- Course Row -->
                        @foreach(var course in item.Courses)
                        {
                            <div class="course-row">
                                <div class="course-info">
                                    <div class="course-title">@course.CourseName</div>
                                    <div class="course-meta">
                                        <span class="status-badge draft"><i class="fas fa-pencil-alt"></i> Draft</span>
                                        <div class="progress-mini">
                                            <span>@course.DurationInHours</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="course-actions">
                                    <a asp-area="Instractor"
                                       asp-controller="Home"
                                       asp-action="Details"
                                       asp-route-id="@course.Id"
                                       class="btn btn-secondary">
                                        <i class="fas fa-eye"></i> View
                                    </a>

                                </div>
                            </div>
                        }
                    </div>
                </div>

               
            }




            </div>
        </div>
    </section>

    

    <!-- ========================================
         4️⃣ EMPLOYEES PROGRESS TABLE
         ======================================== -->
    <section class="section-container">
        <div class="section-header">
            <i class="fas fa-users"></i>
            <h2>Employee Progress</h2>
        </div>
        <div class="section-body">
            <div class="table-header">
                <h3>Employee List</h3>
                <a href="#" class="btn btn-success"><i class="fas fa-plus"></i> Add Employee</a>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Course Name</th>
                        <th>Completion</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
            <tbody>
                @if(Model.Employees is not null)
                {
                    @foreach (var item in Model.Employees)
                    {
                        <tr>
                            <td>
                                <div class="employee-cell">
                                    <div>
                                        <div style="font-weight: 600;">@item.Name</div>
                                        <div class="text-muted" style="font-size: 0.8rem;">@item.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                            <td>
                                @foreach (var course in item.EnrolledCourses)
                                {
                                    <div class="mb-2">
                                        <small class="d-block">@course.CourseName</small>
                                        <div class="completion-cell">
                                            <div class="completion-bar">
                                                <div class="fill @(course.ProgressPercentage > 70 ? "high" : "low")"
                                                     style="width: @course.ProgressPercentage%;"></div>
                                            </div>
                                            <span style="font-size: 0.7rem;">@course.ProgressPercentage%</span>
                                        </div>
                                    </div>
                                }
                            </td>

                            <td>
                                <span class="status-badge @(item.IsActive ? "active" : "inactive")">
                                    <i class="fas fa-circle" style="font-size: 6px;"></i>
                                    @(item.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <div class="actions-cell">
                                    <button class="btn-icon edit" title="Details"><i class="fas fa-eye"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                }
               
            </tbody>
            </table>
        </div>
     </section>


