@model IEnumerable<CategoryVm>
@if (TempData["SuccessMessage"] != null)
{
    <div class="toast-container position-fixed top-0 end-0 p-4" style="z-index: 9999;">
        <div class="toast align-items-center text-bg-success border-0 show" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                </div>
                <button type="button"
                        class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast">
                </button>
            </div>
        </div>
    </div>
}

<link rel="stylesheet" href="~/css/category-index.css" asp-append-version="true" />

<div class="container py-4">

    <!-- ================= Header ================= -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1">Course Categories</h1>
            <p class="text-muted mb-0">
                Manage categories and organize company courses
            </p>
        </div>

        <div class="d-flex gap-2 align-items-center">
            <div class="position-relative">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                <input id="categorySearch"
                       type="text"
                       class="form-control ps-5"
                       placeholder="Search categories..." />
            </div>

            <button class="btn btn-view"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#addCategoryPanel">
                <i class="bi bi-plus-lg me-1"></i>
                Add Category
            </button>
        </div>
    </div>

    <!-- ================= Add Category ================= -->
    <div class="collapse show mb-4" id="addCategoryPanel">
        <div class="category-card">
            <div class="d-flex gap-3 align-items-start">
                <i class="bi bi-folder-plus category-icon"></i>

                <div class="flex-grow-1">
                    <div class="category-title mb-1">Create a new category</div>
                    <div class="text-muted mb-3">
                        Use clear names like “Backend”, “Frontend”, “Data Structure”.
                    </div>

                    <form asp-area="Company"
                          asp-controller="Category"
                          asp-action="CreateCategory"
                          method="post"
                          class="d-flex gap-2 flex-wrap">

                        <input name="CategoryName"
                               type="text"
                               class="form-control"
                               placeholder="Category name..."
                               required />

                        <button type="submit"
                                class="btn btn-add">
                            <i class="bi bi-check2-circle me-1"></i>
                            Create
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= Categories Grid ================= -->
    <div class="row g-4">

        @if (Model == null || !Model.Any())
        {
            <div class="col-12">
                <div class="empty">
                    <i class="bi bi-inboxes fs-3 mb-2 d-block"></i>
                    No categories yet. Create your first category 🚀
                </div>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                var catId = item.Id;
                var collapseId = $"cat_{catId}";
                var coursesCount = item.Courses?.Count ?? 0;

                <div class="col-12 col-md-6 cat-col"
                     data-name="@item.CategoryName.ToLower()">

                    <div class="category-card">

                        <!-- Card Header -->
                        <div class="category-header">

                            <div class="category-left">
                                <i class="bi bi-folder2-open category-icon"></i>

                                <div>
                                    <h5 class="category-title">@item.CategoryName</h5>

                                    <span class="course-count @(coursesCount == 0 ? "empty" : "")">
                                        @coursesCount course@(coursesCount == 1 ? "" : "s")
                                    </span>
                                </div>
                            </div>

                            <div class="category-actions">
                                <a asp-area="Company"
                                   asp-controller="Course"
                                   asp-action="CourseDisplay"
                                   asp-route-categoryId="@item.Id">
                                    View Courses
                                </a>

                                <button class="btn btn-toggle"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#@collapseId">
                                    <i class="bi bi-chevron-down"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Courses -->
                        <div id="@collapseId" class="collapse mt-3">
                            <div>

                                @if (item.Courses == null || !item.Courses.Any())
                                {
                                    <div class="empty">
                                        <i class="bi bi-journal-x me-2"></i>
                                        No courses in this category yet
                                    </div>
                                }
                                else
                                {
                                    foreach (var course in item.Courses)
                                    {
                                        <div class="course-item">
                                            <div>
                                                <strong>@course.CourseName</strong>
                                                <div class="instructor">
                                                    @(string.IsNullOrWhiteSpace(course.InstructorName)
                                                                                        ? "Not assigned yet"
                                                                                        : course.InstructorName)
                                                </div>
                                            </div>

                                            <span class="course-badge">
                                                Course
                                            </span>
                                        </div>
                                    }
                                }

                            </div>
                        </div>

                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        // Simple category search
        document.getElementById('categorySearch')
            ?.addEventListener('input', function () {
                const q = this.value.toLowerCase();
                document.querySelectorAll('.cat-col').forEach(el => {
                    const name = el.getAttribute('data-name');
                    el.style.display = name.includes(q) ? '' : 'none';
                });
            });

           setTimeout(() => {
            const toast = document.querySelector('.toast');
            if (toast) toast.classList.remove('show');
        }, 3500);
    </script>
}
