@model List<LessonDisplayVm>

@{
    ViewData["Title"] = "Course Lessons";
    var courseId = ViewBag.CourseId;
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Course Lessons</h3>

        <a asp-action="AddLesson"
           asp-route-courseId="@courseId"
           class="btn btn-primary">
            + Add Lesson
        </a>
    </div>

    @if (!Model.Any())
    {
        <!-- No Lessons -->
        <div class="alert alert-info">
            This course has no lessons yet.
        </div>

        <a asp-action="AddLesson"
           asp-route-courseId="@courseId"
           class="btn btn-success">
            Add First Lesson
        </a>
    }
    else
    {
        <!-- Lessons List -->
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:10%">Order</th>
                            <th style="width:25%">Title</th>
                            <th>Description</th>
                            <th style="width:15%">Content</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lesson in Model)
                        {
                            <tr>
                                <td>@lesson.Order</td>
                                <td>@lesson.Title</td>
                                <td>@lesson.Description</td>
                                <td>
                                    <a href="@lesson.ContentUrl"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Back -->
    <div class="mt-4">
        <a asp-action="EditCourse"
           asp-route-id="@courseId"
           class="btn btn-secondary">
            Back to Course
        </a>
    </div>

</div>
