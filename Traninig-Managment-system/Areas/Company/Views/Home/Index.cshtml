@model CompanyOverviewVm

@{
    // Status calculation
    var statusClass = "status-active";
    var progressColor = "success";

    if (Model.DaysRemaining <= 7)
    {
        statusClass = "status-critical";
        progressColor = "danger";
    }
    else if (Model.DaysRemaining <= 30)
    {
        statusClass = "status-warning";
        progressColor = "warning";
    }

    // Progress calculation
    var totalDays = (Model.ExpirationDate.Date - Model.RegistrationDate.Date).Days;
    if (totalDays <= 0) totalDays = 1;

    var consumedDays = (DateTime.UtcNow.Date - Model.RegistrationDate.Date).Days;
    if (consumedDays < 0) consumedDays = 0;
    if (consumedDays > totalDays) consumedDays = totalDays;

    var timeConsumedPercentage = (int)Math.Round((consumedDays * 100.0) / totalDays);
    if (timeConsumedPercentage < 0) timeConsumedPercentage = 0;
    if (timeConsumedPercentage > 100) timeConsumedPercentage = 100;
}

<link rel="stylesheet" href="~/css/company-overview-clean.css" asp-append-version="true" />

<div class="overview-container">
    <div class="container-fluid px-4 py-4">

        <div class="row g-4">

            <!-- Left Column - Timer -->
            <div class="col-lg-4">
                <div class="timer-card @statusClass"
                     id="countdown"
                     data-expiration="@Model.ExpirationDate.ToString("yyyy-MM-ddTHH:mm:ss")">

                    <!-- Header -->
                    <div class="timer-header">
                        <div class="timer-icon">
                            <i class="bi bi-hourglass-split"></i>
                        </div>
                        <div class="timer-title">
                            <h3>Access Expires In</h3>
                            <p class="live-badge">
                                <span class="pulse-dot"></span>
                                Live countdown
                            </p>
                        </div>
                        <div class="days-badge">
                            <span class="days-number">@Model.DaysRemaining</span>
                            <span class="days-text">DAYS</span>
                        </div>
                    </div>

                    <!-- Countdown Grid -->
                    <div class="countdown-grid">
                        <div class="countdown-box">
                            <div class="countdown-value" id="days">@Model.DaysRemaining</div>
                            <div class="countdown-label">DAYS</div>
                        </div>
                        <div class="countdown-separator">:</div>
                        <div class="countdown-box">
                            <div class="countdown-value" id="hours">00</div>
                            <div class="countdown-label">HOURS</div>
                        </div>
                        <div class="countdown-separator">:</div>
                        <div class="countdown-box">
                            <div class="countdown-value" id="minutes">00</div>
                            <div class="countdown-label">MINUTES</div>
                        </div>
                        <div class="countdown-separator">:</div>
                        <div class="countdown-box">
                            <div class="countdown-value" id="seconds">00</div>
                            <div class="countdown-label">SECONDS</div>
                        </div>
                    </div>

                    <!-- Progress Bar -->
                    <div class="progress-section">
                        <div class="progress-labels">
                            <span>@timeConsumedPercentage% used</span>
                            <span>@(100 - timeConsumedPercentage)% left</span>
                        </div>
                        <div class="progress-bar-wrapper">
                            <div class="progress-bar-fill @progressColor"
                                 style="width: @timeConsumedPercentage%"></div>
                        </div>
                    </div>

                    <!-- Dates -->
                    <div class="dates-section">
                        <div class="date-item">
                            <i class="bi bi-calendar-check"></i>
                            <div class="date-info">
                                <span class="date-label">STARTED</span>
                                <span class="date-value">@Model.RegistrationDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                        <div class="date-divider"></div>
                        <div class="date-item">
                            <i class="bi bi-calendar-x"></i>
                            <div class="date-info">
                                <span class="date-label">EXPIRES</span>
                                <span class="date-value">@Model.ExpirationDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    </div>

                    @if (Model.DaysRemaining <= 30)
                    {
                        <button class="btn-renew">
                            <i class="bi bi-arrow-repeat"></i>
                            Renew Subscription
                        </button>
                    }
                </div>
            </div>

            <!-- Right Column - Metrics -->
            <div class="col-lg-8">
                <div class="metrics-card">

                    <!-- Header -->
                    <div class="metrics-header">
                        <div class="header-left">
                            <i class="bi bi-graph-up"></i>
                            <div>
                                <h3>Performance Metrics</h3>
                                <p>Real-time performance indicators</p>
                            </div>
                        </div>
                        <div class="time-filters">
                            <button class="filter-btn active">Today</button>
                            <button class="filter-btn">Week</button>
                            <button class="filter-btn">Month</button>
                        </div>
                    </div>

                    <!-- Metrics Grid -->
                    <div class="metrics-grid">

                        <!-- Total Courses -->
                        <div class="metric-item">
                            <div class="metric-icon courses">
                                <i class="bi bi-journal-text"></i>
                            </div>
                            <div class="metric-content">
                                <div class="metric-label">TOTAL COURSES</div>
                                <div class="metric-value-row">
                                    <span class="metric-value" data-count="@Model.TotalCourses">@Model.TotalCourses</span>
                                    <span class="metric-trend up">
                                        <i class="bi bi-arrow-up"></i>
                                        12%
                                    </span>
                                </div>
                                <div class="metric-subtitle">vs last month</div>
                            </div>
                            <div class="metric-chart">
                                <svg viewBox="0 0 100 30">
                                    <polyline points="0,25 25,20 50,22 75,15 100,10"
                                              fill="none"
                                              stroke="currentColor"
                                              stroke-width="2" />
                                </svg>
                            </div>
                        </div>

                        <!-- Active Instructors -->
                        <div class="metric-item">
                            <div class="metric-icon instructors">
                                <i class="bi bi-person-badge"></i>
                            </div>
                            <div class="metric-content">
                                <div class="metric-label">ACTIVE INSTRUCTORS</div>
                                <div class="metric-value-row">
                                    <span class="metric-value" data-count="@Model.ActiveInstructors">@Model.ActiveInstructors</span>
                                    <span class="metric-trend up">
                                        <i class="bi bi-arrow-up"></i>
                                        8%
                                    </span>
                                </div>
                                <div class="metric-subtitle">Currently teaching</div>
                            </div>
                            <div class="metric-chart">
                                <svg viewBox="0 0 100 30">
                                    <polyline points="0,20 25,18 50,15 75,12 100,8"
                                              fill="none"
                                              stroke="currentColor"
                                              stroke-width="2" />
                                </svg>
                            </div>
                        </div>

                        <!-- Total Students -->
                        <div class="metric-item">
                            <div class="metric-icon students">
                                <i class="bi bi-people-fill"></i>
                            </div>
                            <div class="metric-content">
                                <div class="metric-label">TOTAL STUDENTS</div>
                                <div class="metric-value-row">
                                    <span class="metric-value" data-count="@Model.TotalStudents">@Model.TotalStudents</span>
                                    <span class="metric-trend up">
                                        <i class="bi bi-arrow-up"></i>
                                        24%
                                    </span>
                                </div>
                                <div class="metric-subtitle">Enrolled employees</div>
                            </div>
                            <div class="metric-chart">
                                <svg viewBox="0 0 100 30">
                                    <polyline points="0,28 25,25 50,20 75,16 100,5"
                                              fill="none"
                                              stroke="currentColor"
                                              stroke-width="2" />
                                </svg>
                            </div>
                        </div>

                        <!-- Completion Rate -->
                        <div class="metric-item">
                            <div class="metric-icon completion">
                                <i class="bi bi-trophy-fill"></i>
                            </div>
                            <div class="metric-content">
                                <div class="metric-label">COMPLETION RATE</div>
                                <div class="metric-value-row">
                                    <span class="metric-value" data-count="@Model.CompletionRate">0</span>
                                    <span class="metric-unit">%</span>
                                    <span class="metric-trend up">
                                        <i class="bi bi-arrow-up"></i>
                                        5%
                                    </span>
                                </div>
                                <div class="metric-subtitle">Average completion</div>
                            </div>
                            <div class="metric-progress-circle">
                                <svg viewBox="0 0 36 36">
                                    <path class="circle-bg"
                                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                          fill="none"
                                          stroke="currentColor"
                                          stroke-width="2"
                                          opacity="0.2" />
                                    <path class="circle-fill"
                                          stroke-dasharray="@Model.CompletionRate, 100"
                                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                          fill="none"
                                          stroke="currentColor"
                                          stroke-width="2" />
                                </svg>
                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>

    </div>
</div>
@section scripts{
    <script>
        document.addEventListener('DOMContentLoaded', () => {

            const countdown = document.getElementById('countdown');

            if (countdown) {
                const endTime = new Date(countdown.dataset.expiration).getTime();

                const daysEl = document.getElementById('days');
                const hoursEl = document.getElementById('hours');
                const minutesEl = document.getElementById('minutes');
                const secondsEl = document.getElementById('seconds');

                const tick = () => {
                    const now = Date.now();
                    let diff = endTime - now;

                    if (diff <= 0) diff = 0;

                    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
                    const minutes = Math.floor((diff / (1000 * 60)) % 60);
                    const seconds = Math.floor((diff / 1000) % 60);

                    daysEl.textContent = days;
                    hoursEl.textContent = String(hours).padStart(2, '0');
                    minutesEl.textContent = String(minutes).padStart(2, '0');
                    secondsEl.textContent = String(seconds).padStart(2, '0');
                };

                tick();
                setInterval(tick, 1000);
            }

            function animateCounter(el) {
                const target = Number(el.dataset.count);
                if (isNaN(target)) return;

                let current = 0;
                const duration = 1200;
                const stepTime = 16;
                const increment = target / (duration / stepTime);

                const counter = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                        el.textContent = target;
                        clearInterval(counter);
                    } else {
                        el.textContent = Math.floor(current);
                    }
                }, stepTime);
            }

            const observer = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting && !entry.target.dataset.animated) {
                        animateCounter(entry.target);
                        entry.target.dataset.animated = "true";
                    }
                });
            }, { threshold: 0.2 });

            document.querySelectorAll('[data-count]').forEach(el => {
                el.textContent = '0';
                observer.observe(el);
            });

            console.log('✅ Company Overview JS Ready');
        });
    </script>

}
