<!-- ══════════════════════════════════════════════════════════════════
         COURSE MANAGEMENT SECTION
    ══════════════════════════════════════════════════════════════════ -->
<section id="management" class="mb-5">
    <div class="section-header">
        <h2 class="section-title">
            <i class="bi bi-cloud-upload"></i>
            Course Management
        </h2>
    </div>

    <div class="row">
        <!-- Upload New Course -->
        <div class="col-lg-6 mb-4">
            <div class="card" id="course-management">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-plus-circle me-2"></i>
                        Upload New Course
                    </h5>
                </div>
                <div class="card-body">
                    <form id="uploadCourseForm">
                        <div class="mb-3">
                            <label for="courseName" class="form-label">Course Name</label>
                            <input type="text" class="form-control" id="courseName" placeholder="Enter course name">
                        </div>

                        <div class="mb-3">
                            <label for="video" class="form-label">Upload Video</label>
                            <input type="file" class="form-control" id="video" accept="video/*">
                        </div>

                        <div class="mb-3">
                            <label for="courseCategory" class="form-label">Category</label>
                            <select class="form-select" id="courseCategory">
                                <option selected disabled>Choose category...</option>
                                <option value="programming">Programming & Development</option>
                                <option value="datascience">Data Science & Analytics</option>
                                <option value="design">Design & UX</option>
                                <option value="mobile">Mobile Development</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="courseInstructor" class="form-label">Instructor</label>
                            <select class="form-select" id="courseInstructor">
                                <option selected disabled>Assign instructor...</option>
                                <option value="emad">Emad</option>
                                <option value="naira">Naira</option>
                                <option value="merna">Merna</option>
                                <option value="ahmed">Ahmed</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="coursePDF" class="form-label">Course Material (PDF)</label>
                            <input type="file" class="form-control" id="coursePDF" accept=".pdf">
                            <div class="form-text">Upload PDF files only. Max size: 50MB</div>
                        </div>

                        <div class="mb-3">
                            <label for="courseDescription" class="form-label">Description</label>
                            <textarea class="form-control" id="courseDescription" rows="3" placeholder="Brief course description..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-upload me-2"></i>
                            Upload Course
                        </button>
                    </form>
                </div>
            </div>
        </div>

       
    </div>
</section>